{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:5174",
    "distDir": "../dist",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "Lattice Admin",
    "version": "0.1.0"
  },
  "tauri": {
    "bundle": {
      "active": true,
      "identifier": "dev.lattice.admin",
      "targets": "all",
      "category": "Utility",
      "shortDescription": "Lattice mesh administrator console",
      "longDescription": "Manage membership, inspect traffic, and study the tunnel crypto on a Lattice mesh you administer."
    },
    "windows": [
      {
        "title": "Lattice Admin",
        "width": 980,
        "height": 720,
        "minWidth": 820,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    },
    "allowlist": {
      "all": false
    }
  }
}
