#!/usr/bin/env python3
r"""
lattice — a friendly command-line client for the v2 mesh daemon (`meshd`).

`meshd` speaks newline-delimited JSON over a unix socket. This wraps that wire
in human subcommands so you never hand-write JSON. Zero dependencies (Python 3
stdlib only).

Quick start:
    lattice new home --me alice          # create a mesh, become member #1
    lattice id                           # (on a 2nd machine) print an identity code
    lattice invite home bob <id-code>    # (on the host) mint an invite for bob
    lattice join <invite-code>           # (on the 2nd machine) join with it
    lattice ls                           # list meshes
    lattice info home                    # members, liveness, exit, cipher
    lattice exit home alice              # pick alice as the internet exit
    lattice vpn home                     # route ALL traffic through that exit
    lattice off                          # back to direct internet

Headless server (no GUI to run the daemon):
    lattice install                      # put `lattice` on PATH (/usr/local/bin)
    sudo lattice up                      # start meshd in the background (needs root)
    lattice status [--watch 2]           # daemon health + meshes/exit/traffic
    lattice logs -f                      # follow the daemon log
    sudo lattice install-service --advertise <ip>:41000   # start at boot (systemd)
    lattice serve-exit home              # make THIS node the mesh's internet exit
    ssh joiner lattice id | lattice invite home bob -      # pipe the invite flow
    lattice down                         # stop the daemon cleanly (no sudo)

The socket defaults to $LATTICE_SOCK or /tmp/lattice-meshd.sock
(Windows: \\.\pipe\lattice-meshd — use --sock to override). The daemon log
defaults to $LATTICE_LOG or /tmp/lattice-meshd.log.
"""

import argparse
import base64
import json
import os
import platform
import shutil
import socket
import subprocess
import sys
import time

DEFAULT_SOCK = os.environ.get("LATTICE_SOCK", "/tmp/lattice-meshd.sock")
DEFAULT_LOG = os.environ.get("LATTICE_LOG", "/tmp/lattice-meshd.log")
SERVICE_NAME = "lattice-meshd"
SERVICE_UNIT = f"/etc/systemd/system/{SERVICE_NAME}.service"


# ----------------------------- transport -----------------------------
def call(sock_path, request):
    """Send one Request dict, return the parsed Response dict (or raise)."""
    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    s.settimeout(10)
    try:
        s.connect(sock_path)
    except (FileNotFoundError, ConnectionRefusedError) as e:
        die(f"meshd not reachable at {sock_path} ({e}). Is the daemon running?")
    buf = b""
    try:
        s.sendall((json.dumps(request) + "\n").encode())
        while not buf.endswith(b"\n"):
            chunk = s.recv(65536)
            if not chunk:
                break
            buf += chunk
    except (BrokenPipeError, ConnectionResetError, OSError) as e:
        die(_refused_hint(f"meshd closed the connection ({e})"))
    finally:
        s.close()
    if not buf.strip():
        die(_refused_hint("meshd accepted the connection then closed it with no reply"))
    reply = json.loads(buf.decode().strip())
    if isinstance(reply, dict) and "Error" in reply:
        die("meshd: " + reply["Error"].get("message", "unknown error"))
    return reply


def die(msg):
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)


def _refused_hint(what):
    """Message for a connection the daemon accepted then dropped — usually the
    LATTICE_ALLOW_UID access gate refusing this uid (meshd logs the refusal)."""
    return (f"{what}. If LATTICE_ALLOW_UID is set on the daemon, this user is not "
            f"allowed — run as an allowed uid (e.g. `sudo lattice …`) or add this "
            f"uid to LATTICE_ALLOW_UID.")


# ----------------------------- helpers -----------------------------
def b64(obj):
    return base64.urlsafe_b64encode(json.dumps(obj).encode()).decode()


def unb64(s):
    try:
        return json.loads(base64.urlsafe_b64decode(s.strip().encode()))
    except Exception as e:
        die(f"malformed code: {e}")


def read_code(arg):
    """A code argument of '-' (or omitted via stdin pipe) is read from stdin — so
    codes can be piped between machines: `ssh joiner lattice id | lattice invite m bob -`."""
    if arg == "-":
        data = sys.stdin.read().strip()
        if not data:
            die("expected a code on stdin (got nothing).")
        # Take the last non-comment line (lattice id/invite print hints to stderr, code to stdout,
        # but if both were captured, the code is the last bare token).
        for line in reversed(data.splitlines()):
            line = line.strip()
            if line and not line.startswith("#"):
                return line
        die("no code found on stdin.")
    return arg


def resolve_mesh(sock, ref):
    """Accept a mesh id (number) or a mesh name; return the numeric id. Refuses to guess
    when a name is ambiguous (duplicate names) — pick the numeric id instead."""
    if ref.isdigit():
        return int(ref)
    meshes = call(sock, "ListMeshes").get("Meshes", [])
    matches = [m for m in meshes if m["name"] == ref]
    if len(matches) > 1:
        ids = ", ".join(f"#{m['id']}" for m in matches)
        die(f"ambiguous: {len(matches)} meshes named '{ref}' ({ids}) — use the numeric id")
    if matches:
        return matches[0]["id"]
    die(f"no mesh named '{ref}' (try `lattice ls`)")


def resolve_member(sock, mesh_id, ref):
    """Accept a member id (number) or an in-mesh name; return the numeric id. Refuses to
    guess when a name is ambiguous (duplicate names) — pick the numeric id instead."""
    if ref.isdigit():
        return int(ref)
    detail = call(sock, {"MeshInfo": {"mesh": mesh_id}})["Mesh"]
    matches = [mb for mb in detail["members"] if mb["name"] == ref]
    if len(matches) > 1:
        ids = ", ".join(f"#{mb['id']}" for mb in matches)
        die(f"ambiguous: {len(matches)} members named '{ref}' ({ids}) — use the numeric id")
    if matches:
        return matches[0]["id"]
    die(f"no member named '{ref}' in mesh {mesh_id} (try `lattice info {mesh_id}`)")


# ----------------------------- commands -----------------------------
def cmd_ls(sock, a):
    meshes = call(sock, "ListMeshes").get("Meshes", [])
    if not meshes:
        print("no meshes yet — create one with `lattice new <name>`")
        return
    print(f"{'ID':>2}  {'NAME':<16} {'MEMBERS':>7} {'EPOCH':>5}  {'EXIT':>5}  EGRESS")
    for m in meshes:
        egress = "→ THIS MESH" if m.get("is_current") else "direct"
        exit_s = f"#{m['exit']}" if m.get("exit") is not None else "—"
        flag = " ⚠ATTACK" if m.get("attack_armed_secs_left") is not None else ""
        print(f"{m['id']:>2}  {m['name']:<16} {m['members']:>7} {m['epoch']:>5}  "
              f"{exit_s:>5}  {egress}{flag}")


def cmd_info(sock, a):
    mid = resolve_mesh(sock, a.mesh)
    d = call(sock, {"MeshInfo": {"mesh": mid}})["Mesh"]
    sd = "ephemeral (self-destruct when isolated)" if d.get("self_destruct") else "persistent"
    print(f"mesh #{d['id']}  {d['name']}    net {d.get('network_fp', '?')}")
    print(f"  cipher     {d['cipher']}   epoch {d['epoch']}")
    print(f"  charter    {d['invite']} · {d['trigger']} · max {d['max_members']} · {sd}")
    print(f"  expel      {d.get('expel', '?')}")
    print(f"  header     {d.get('header_placement', '?')}")
    print(f"  health     {d['live']}/{len(d['members'])} live · floor {d['threshold']}")
    if d.get("attack_armed_secs_left") is not None:
        print(f"  ⚠ ATTACK   self-destruct in {d['attack_armed_secs_left']}s "
              f"(creator: `lattice allclear {d['name']}`)")
    print(f"  exit       {('#' + str(d['exit'])) if d['exit'] is not None else 'none'}")
    print("  members:        (overlay IP = reach it over the tunnel, e.g. ssh user@<overlay-ip>)")
    for mb in d["members"]:
        me = " (me)" if mb["is_me"] else ""
        ep = mb.get("endpoint") or "—"
        ov = mb.get("overlay_ip") or "?"
        print(f"    #{mb['id']:<3} {mb['name']:<14} {ov:<14} {mb['state']:<8} {ep}{me}")
        if mb.get("reason"):
            print(f"         └ {mb['reason']}")
    warns = d.get("warnings") or []
    if warns:
        print("  warnings:")
        for w in warns:
            print(f"    {w}")
        print("  → `lattice doctor` for a diagnosis + suggested fix.")


def cmd_new(sock, a):
    req = {"CreateMesh": {
        "name": a.name, "my_name": a.me, "max_members": a.max,
        "cipher": a.cipher, "self_destruct": a.ephemeral,
        "master_gated": a.master_gated, "expel": a.expel, "header": a.header}}
    r = call(sock, req)
    mid = r["MeshCreated"]["mesh"]
    print(f"created mesh #{mid} '{a.name}' — you are '{a.me}'.")
    print(f"invite someone: ask them for `lattice id`, then `lattice invite {a.name} <name> <id-code>`")


def cmd_id(sock, a):
    r = call(sock, "NewIdentity")["Identity"]
    print("# Your identity code — send this ONE line to the mesh host:", file=sys.stderr)
    print("# (valid ~10 min; host runs: lattice invite <mesh> <your-name> <this-code>)",
          file=sys.stderr)
    print(b64(r))  # stdout = just the code, so `$(lattice id)` is clean


def cmd_invite(sock, a):
    mid = resolve_mesh(sock, a.mesh)
    ident = unb64(read_code(a.id_code))
    req = {"CreateInvite": {
        "mesh": mid, "name": a.name,
        "member_pubkey_hex": ident["member_pubkey_hex"],
        "enc_pubkey_hex": ident["enc_pubkey_hex"],
        "issued_at": ident.get("issued_at", 0)}}
    if a.algo:
        req["CreateInvite"]["algo"] = a.algo
    inv = call(sock, req)["Invite"]
    print("# Invite code — send this ONE line back to the joiner:", file=sys.stderr)
    if a.algo:
        print(f"# Tell them the invite-algorithm out-of-band: {a.algo}", file=sys.stderr)
    print(b64(inv))  # stdout = just the code


def cmd_join(sock, a):
    inv = unb64(read_code(a.invite_code))
    req = {"JoinMesh": {"invite": inv}}
    if a.algo:
        req["JoinMesh"]["algo"] = a.algo
    r = call(sock, req)
    mid = r.get("MeshCreated", {}).get("mesh")
    print(f"joined mesh #{mid}. `lattice info {mid}` to see peers.")


def cmd_exit(sock, a):
    mid = resolve_mesh(sock, a.mesh)
    eid = resolve_member(sock, mid, a.member)
    call(sock, {"SetExit": {"mesh": mid, "exit": eid}})
    print(f"exit for mesh {mid} set to member #{eid}. `lattice vpn {a.mesh}` to route through it.")


def cmd_vpn(sock, a):
    mid = resolve_mesh(sock, a.mesh)
    call(sock, {"SetCurrent": {"mesh": mid}})
    print(f"full tunnel ON — all internet traffic now exits via mesh {mid}. `lattice off` to stop.")


def cmd_off(sock, a):
    call(sock, {"SetCurrent": {"mesh": None}})
    print("full tunnel OFF — back to direct internet.")


def cmd_recipher(sock, a):
    mid = resolve_mesh(sock, a.mesh)
    req = {"Recipher": {"mesh": mid, "cipher": a.cipher}}
    call(sock, req)
    print(f"mesh {mid} re-ciphered (epoch bumped). Offline members were evicted.")


def cmd_attack(sock, a):
    mid = resolve_mesh(sock, a.mesh)
    call(sock, {"ReportAttack": {"mesh": mid}})
    print(f"⚠ attack reported on mesh {mid}. Every member self-destructs unless the "
          f"creator runs `lattice allclear {a.mesh}` within the grace window.")


def cmd_allclear(sock, a):
    mid = resolve_mesh(sock, a.mesh)
    call(sock, {"AllClear": {"mesh": mid}})
    print(f"all-clear sent for mesh {mid} — self-destruct cancelled.")


def _fmt_bytes(n):
    for u in ("B", "KB", "MB", "GB"):
        if n < 1024 or u == "GB":
            return f"{n:.0f}{u}" if u == "B" else f"{n/1:.0f}{u}" if False else f"{n:.1f}{u}"
        n /= 1024


def cmd_traffic(sock, a):
    req = {"TrafficStats": {"mesh": resolve_mesh(sock, a.mesh) if a.mesh else None}}
    t = call(sock, req)["Traffic"]
    scope = f"mesh {a.mesh}" if a.mesh else "this computer (all meshes)"
    print(f"traffic — {scope}")
    print(f"  total   ↓ {t['rx_bytes']}B / {t['rx_pkts']} pkts   ↑ {t['tx_bytes']}B / {t['tx_pkts']} pkts")
    print("  peers:")
    for p in t["peers"]:
        tag = f"[{p['mesh_name']}] " if not a.mesh else ""
        print(f"    {tag}{p['name']} #{p['id']}   ↓ {p['rx_bytes']}B/{p['rx_pkts']}   ↑ {p['tx_bytes']}B/{p['tx_pkts']}")
    if a.detail:
        print("  recent flows (newest first):")
        for f in t["recent"][:40]:
            arrow = "↑out" if f["out"] else "↓in "
            port = f":{f['sport']}→{f['dport']}" if f["sport"] or f["dport"] else ""
            ex = " via-exit" if f["via_exit"] else ""
            sn = f.get("src_node") or ""; dn = f.get("dst_node") or ""
            src = f"{sn}({f['src']})" if sn else f["src"]
            dst = f"{dn}({f['dst']})" if dn else f["dst"]
            print(f"    {arrow} {f['proto']} {src}→{dst}{port} {f['bytes']}B  req:{sn or f['member_name']}{ex}")


def cmd_expel(sock, a):
    mid = resolve_mesh(sock, a.mesh)
    eid = resolve_member(sock, mid, a.member)
    r = call(sock, {"ExpelMember": {"mesh": mid, "member": eid}})
    msg = r.get("Info", {}).get("message") if isinstance(r, dict) else None
    print(msg or f"expel sent for member #{eid}.")


def _fmt_action(act):
    # FlowAction is a serde enum: "ToOverlayOwner"/"Local"/"Drop" (unit) or
    # {"ToExit": null|id} / {"ToPeer": id}.
    if isinstance(act, str):
        return act
    if isinstance(act, dict):
        k, v = next(iter(act.items()))
        if k == "ToExit":
            return "ToExit(default)" if v is None else f"ToExit(node {v})"
        return f"{k}({v})"
    return str(act)


def _fmt_match(m):
    parts = []
    if m.get("scope") is not None:
        parts.append(m["scope"].lower())
    if m.get("dst_cidr") is not None:
        net, ln = m["dst_cidr"]
        parts.append(f"dst {net}/{ln}")
    if m.get("proto") is not None:
        parts.append({1: "icmp", 6: "tcp", 17: "udp"}.get(m["proto"], f"proto {m['proto']}"))
    if m.get("dport") is not None:
        parts.append(f"dport {m['dport']}")
    return ", ".join(parts) if parts else "any"


def _parse_cidr(s):
    if "/" in s:
        net, ln = s.split("/", 1)
        return [net, int(ln)]
    return [s, 32]


def cmd_flows(sock, a):
    mid = resolve_mesh(sock, a.mesh)
    if a.reset:
        # An empty table tells meshd to fall back to the built-in default at restore;
        # but to apply live we send the default explicitly by asking for a no-op edit.
        # Simplest: send the current default by clearing to [] is rejected, so we ship
        # the daemon's default by reading it after a fresh create — instead just send the
        # known default (overlay→owner, internet→exit).
        rules = [
            {"priority": 0, "match_": {"scope": "Overlay", "dst_cidr": None, "proto": None, "dport": None},
             "action": "ToOverlayOwner"},
            {"priority": 0, "match_": {"scope": "Internet", "dst_cidr": None, "proto": None, "dport": None},
             "action": {"ToExit": None}},
        ]
        r = call(sock, {"SetFlows": {"mesh": mid, "flows": rules}})
        print((r.get("Info") or {}).get("message", "flow table reset to default."))
        return

    rules = call(sock, {"GetFlows": {"mesh": mid}}).get("FlowRules", [])

    if a.block or a.exit:
        if a.block:
            m = {"scope": None, "dst_cidr": _parse_cidr(a.block), "proto": None, "dport": None}
            action = "Drop"
            label = f"block {a.block}"
        else:
            m = {"scope": None, "dst_cidr": _parse_cidr(a.exit), "proto": None, "dport": None}
            action = {"ToExit": None}
            label = f"route {a.exit} via exit"
        # Higher priority than the defaults (which are priority 0) so it wins.
        rules = list(rules) + [{"priority": 100, "match_": m, "action": action}]
        r = call(sock, {"SetFlows": {"mesh": mid, "flows": rules}})
        print((r.get("Info") or {}).get("message", f"added rule: {label}."))
        return

    # Default: list the table (evaluation order = highest priority first, then order).
    if not rules:
        print("(empty — using the built-in default table)")
        return
    print(f"flow table for mesh {mid} ({len(rules)} rules):")
    for i, ru in enumerate(rules):
        print(f"  [{i}] prio {ru['priority']:<4} {_fmt_match(ru['match_'])}  ->  {_fmt_action(ru['action'])}")


def cmd_rm(sock, a):
    mid = resolve_mesh(sock, a.mesh)
    call(sock, {"RemoveMesh": {"mesh": mid}})
    print(f"mesh {mid} wiped from this computer.")


def cmd_shutdown(sock, a):
    # The root daemon stops itself (the socket is world-writable) — no sudo needed.
    try:
        call(sock, "Shutdown")
    except SystemExit:
        pass  # the daemon may close the connection as it exits — that's expected
    print("daemon shutdown requested — meshd is exiting (data-plane TUN/ports freed).")


def cmd_ciphers(sock, a):
    for c in call(sock, "Ciphers").get("Ciphers", []):
        print(c)


def cmd_algos(sock, a):
    for c in call(sock, "InviteAlgorithms").get("Ciphers", []):
        print(c)


def cmd_policy(sock, a):
    p = call(sock, "GetPolicy")["Policy"]
    print(f"default route: {p['default']}")
    print(f"current mesh:  {p['current_mesh']}")


def cmd_backup(sock, a):
    req = {"ExportState": {"path": a.path}}
    call(sock, req)
    where = a.path or "<tempdir>/lattice-mesh-backup.json"
    print(f"backed up all meshes to {where} — meshd re-imports it on next start "
          f"(then deletes it). Run this before updating/reinstalling.")


def cmd_doctor(sock, a):
    """Diagnose mesh health and suggest a fix — surfaces what the daemon already knows
    (idle reasons, decrypt-fail warnings) and turns it into actionable advice."""
    meshes = call(sock, "ListMeshes").get("Meshes", [])
    if a.mesh:
        want = resolve_mesh(sock, a.mesh)
        meshes = [m for m in meshes if m["id"] == want]
    if not meshes:
        print("no meshes to diagnose — create one with `lattice new <name>`.")
        return
    any_issue = False
    for summ in meshes:
        d = call(sock, {"MeshInfo": {"mesh": summ["id"]}})["Mesh"]
        issues = []   # (symptom, suggested fix)
        if d.get("dp_error"):
            issues.append((f"data plane DOWN: {d['dp_error']}",
                           "다른 프로세스가 UDP 포트를 잡고 있을 수 있음 — 좀비 meshd 종료 후 재시작."))
        for mb in d["members"]:
            if mb["is_me"] or mb["state"] == "live":
                continue
            r = mb.get("reason") or f"state={mb['state']}"
            name = mb["name"]
            if "복호 실패" in r:
                fix = (f"'{name}'이 다른 mesh/epoch일 가능성 큼. 양쪽 `lattice info`의 net 지문이 "
                       f"같은지 확인하고, 다르면 한쪽을 기준으로 재초대(invite→join)하세요.")
            elif "한 번도 수신" in r:
                fix = (f"'{name}'의 데몬이 켜져 있는지, 방화벽이 UDP를 막는지 확인. 공용 노드면 "
                       f"포트 개방, 아니면 상대가 먼저 이쪽으로 한 번 보내야 NAT가 열립니다.")
            elif "오프라인이거나 IP" in r:
                fix = (f"'{name}'이 잠들었거나 IP가 바뀐 듯. DHT가 켜져 있으면 자동 재발견됩니다 "
                       f"(MESHD_DHT≠0). 계속이면 상대 노드가 꺼진 상태.")
            else:  # unknown
                fix = (f"'{name}'의 주소를 아직 모름. DHT/부트스트랩이 동작 중인지 확인하거나 "
                       f"`lattice` SetPeer로 주소를 직접 줄 수 있습니다.")
            issues.append((f"member '{name}' [{mb['state']}] — {r}", fix))
        for w in (d.get("warnings") or []):
            # warnings already carry the symptom; only add ones not already covered.
            if not any(w[:12] in sym for sym, _ in issues):
                issues.append((w, "위 항목 참고."))

        live, total = d["live"], len(d["members"])
        head = f"mesh #{d['id']} '{d['name']}'  net {d.get('network_fp','?')}  ({live}/{total} live)"
        if not issues:
            print(f"✅ {head} — 정상.")
            continue
        any_issue = True
        print(f"🩺 {head} — {len(issues)}건 발견:")
        for i, (sym, fix) in enumerate(issues, 1):
            print(f"  {i}. {sym}")
            print(f"     ↳ 조치: {fix}")
    if not any_issue:
        print("\n모든 mesh 정상입니다.")


# ============================ server / daemon lifecycle ============================
# A headless server (no GUI to spawn meshd) drives the daemon entirely from here.

def _is_root():
    return hasattr(os, "geteuid") and os.geteuid() == 0


def _script_dir():
    # realpath (not abspath) so a /usr/local/bin/lattice **symlink** resolves back to the
    # repo, where find_meshd() looks for target/release/meshd next to scripts/.
    return os.path.dirname(os.path.realpath(__file__))


def find_meshd():
    """Locate the meshd binary. Order: $LATTICE_MESHD, repo build dirs, installed app,
    then PATH. Returns an absolute path or None."""
    env = os.environ.get("LATTICE_MESHD")
    if env and os.path.exists(env):
        return os.path.abspath(env)
    repo = os.path.dirname(_script_dir())  # scripts/ -> repo root
    candidates = [
        os.path.join(repo, "target", "release", "meshd"),
        os.path.join(repo, "target", "debug", "meshd"),
        os.path.join(repo, "gui", "src-tauri", "resources", "meshd"),
        "/Applications/Lattice.app/Contents/Resources/resources/meshd",
    ]
    for c in candidates:
        if os.path.exists(c):
            return c
    return shutil.which("meshd")


def daemon_running(sock_path):
    """True if a daemon answers on the socket (a stale socket file → False)."""
    try:
        s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        s.settimeout(3)
        s.connect(sock_path)
        s.sendall(b'"ListMeshes"\n')
        s.recv(64)
        s.close()
        return True
    except OSError:
        return False


def wait_for_socket(sock_path, secs=20):
    for _ in range(secs * 2):
        if daemon_running(sock_path):
            return True
        time.sleep(0.5)
    return False


def _meshd_env(a):
    """Build the environment overrides meshd reads, from `up`/service flags."""
    env = {"DATA_PLANE": "1"}
    if getattr(a, "advertise", None):
        env["MESHD_ADVERTISE"] = a.advertise
    if getattr(a, "no_dht", False):
        env["MESHD_DHT"] = "0"
    if getattr(a, "state_dir", None):
        env["MESHD_STATE_DIR"] = a.state_dir
    if getattr(a, "dht_port", None):
        env["MESHD_DHT_PORT"] = str(a.dht_port)
    if getattr(a, "dht_bootstrap", None):
        env["MESHD_DHT_BOOTSTRAP"] = a.dht_bootstrap
    if getattr(a, "bind_port", None):
        env["MESHD_BIND_PORT"] = str(a.bind_port)
    return env


def cmd_up(sock, a):
    if daemon_running(sock):
        print(f"daemon already running on {sock} — `lattice status` to inspect.")
        return
    meshd = a.meshd or find_meshd()
    if not meshd:
        die("meshd binary not found. Build it (`cargo build --release -p lattice-meshd`) "
            "or pass --meshd PATH / set $LATTICE_MESHD.")
    env = _meshd_env(a)
    # meshd needs root for the TUN/route plumbing; re-launch under sudo if we aren't root.
    argv = [meshd, sock]
    if a.foreground:
        full = ([] if _is_root() else ["sudo"]) + \
            (["env"] + [f"{k}={v}" for k, v in env.items()] if not _is_root() else []) + argv
        run_env = dict(os.environ)
        if _is_root():
            run_env.update(env)
        print(f"starting meshd (foreground): {' '.join(full)}")
        os.execvpe(full[0], full, run_env)  # replaces this process; Ctrl-C to stop
        return
    # Background: detach, redirect to the log, poll the socket until it answers.
    log = open(a.log, "a")
    if _is_root():
        run_env = dict(os.environ); run_env.update(env)
        popen_args = argv
    else:
        # `sudo env K=V meshd sock` so the elevated process inherits our overrides.
        run_env = None
        popen_args = ["sudo", "env"] + [f"{k}={v}" for k, v in env.items()] + argv
    print(f"starting meshd: {' '.join(popen_args)}")
    print(f"  log: {a.log}")
    if not _is_root():
        print("  (sudo may prompt for your password — meshd needs root for the TUN)")
    subprocess.Popen(popen_args, env=run_env, stdout=log, stderr=log,
                     stdin=subprocess.DEVNULL, start_new_session=True)
    if wait_for_socket(sock):
        n = len(call(sock, "ListMeshes").get("Meshes", []))
        print(f"daemon UP on {sock} — {n} mesh(es). `lattice status` for details.")
    else:
        die(f"daemon did not come up within 20s — check the log: {a.log}")


def cmd_down(sock, a):
    if not daemon_running(sock):
        print("daemon is not running (nothing to stop).")
        return
    try:
        call(sock, "Shutdown")
    except SystemExit:
        pass  # the daemon closes the connection as it exits — expected
    # Confirm it actually went away.
    for _ in range(10):
        if not daemon_running(sock):
            print("daemon stopped (data-plane TUN/ports freed).")
            return
        time.sleep(0.5)
    print("shutdown requested, but the socket is still answering — check `lattice status`.")


def cmd_restart(sock, a):
    cmd_down(sock, a)
    time.sleep(1)
    cmd_up(sock, a)


def _render_status(sock, a):
    up = daemon_running(sock)
    print(f"daemon    {'UP' if up else 'DOWN'}   socket {sock}")
    meshd = a.meshd or find_meshd()
    print(f"binary    {meshd or 'not found'}")
    print(f"log       {a.log}")
    if not up:
        print("\nstart it with `lattice up` (server) — needs root for the TUN.")
        return
    meshes = call(sock, "ListMeshes").get("Meshes", [])
    pol = call(sock, "GetPolicy").get("Policy", {})
    print(f"egress    {pol.get('default', '?')}")
    print(f"meshes    {len(meshes)}")
    for m in meshes:
        exit_s = f"exit #{m['exit']}" if m.get("exit") is not None else "no-exit"
        cur = " ← egress" if m.get("is_current") else ""
        atk = " ⚠ATTACK" if m.get("attack_armed_secs_left") is not None else ""
        print(f"  #{m['id']:<2} {m['name']:<16} {m['members']} members · {exit_s}{cur}{atk}")
    t = call(sock, {"TrafficStats": {"mesh": None}}).get("Traffic", {})
    print(f"traffic   ↓ {t.get('rx_bytes', 0)}B/{t.get('rx_pkts', 0)}  "
          f"↑ {t.get('tx_bytes', 0)}B/{t.get('tx_pkts', 0)}")


def cmd_status(sock, a):
    if not a.watch:
        _render_status(sock, a)
        return
    try:
        while True:
            # Clear screen + home cursor for a stable live view.
            sys.stdout.write("\033[2J\033[H")
            print(f"lattice status — every {a.watch}s (Ctrl-C to stop)\n")
            _render_status(sock, a)
            sys.stdout.flush()
            time.sleep(a.watch)
    except KeyboardInterrupt:
        return


def cmd_logs(sock, a):
    if not os.path.exists(a.log):
        die(f"no log at {a.log} (set $LATTICE_LOG or --log if meshd logs elsewhere).")
    if a.follow:
        try:
            os.execvp("tail", ["tail", "-n", str(a.lines), "-f", a.log])
        except OSError as e:
            die(f"could not tail: {e}")
    else:
        with open(a.log) as f:
            tail = f.readlines()[-a.lines:]
        sys.stdout.write("".join(tail))


def cmd_serve_exit(sock, a):
    """Make THIS node the internet exit for a mesh (the typical server role)."""
    mid = resolve_mesh(sock, a.mesh)
    d = call(sock, {"MeshInfo": {"mesh": mid}})["Mesh"]
    me = next((mb for mb in d["members"] if mb.get("is_me")), None)
    if not me:
        die("could not find this node in the mesh roster.")
    call(sock, {"SetExit": {"mesh": mid, "exit": me["id"]}})
    print(f"this node (#{me['id']} {me['name']}) is now the exit for mesh '{d['name']}'.")
    print("  NAT + ip-forwarding are enabled automatically while the data plane is up.")
    adv = os.environ.get("MESHD_ADVERTISE")
    if a.advertise:
        print(f"  NOTE: advertise is a daemon-start setting. To pin your public address,")
        print(f"        restart with it:  lattice restart --advertise {a.advertise}")
        print(f"        (or bake it into the service: lattice install-service --advertise {a.advertise})")
    elif not adv:
        print("  TIP: behind NAT, peers learn your public address via DHT/reflection. For a")
        print("       stable public exit, pin it: `lattice restart --advertise <ip>:<port>`.")
    print(f"  peers route through you with:  lattice exit {d['name']} {me['name']}  then  lattice vpn {d['name']}")


def cmd_install_service(sock, a):
    """Install a systemd unit so meshd starts at boot (Linux servers)."""
    if platform.system() != "Linux":
        die("install-service targets systemd (Linux). On macOS use the GUI app or "
            "`lattice up`. On Windows, the installer registers a service.")
    if not _is_root():
        die("install-service writes /etc/systemd and must run as root (use sudo).")
    meshd = a.meshd or find_meshd()
    if not meshd:
        die("meshd binary not found — pass --meshd PATH or set $LATTICE_MESHD.")
    env = _meshd_env(a)
    env_lines = "\n".join(f'Environment="{k}={v}"' for k, v in env.items())
    unit = f"""[Unit]
Description=Lattice mesh VPN daemon (meshd)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
{env_lines}
ExecStart={meshd} {sock}
Restart=always
RestartSec=3
# meshd manages TUN + routes — needs full privileges.
User=root
AmbientCapabilities=CAP_NET_ADMIN CAP_NET_RAW

[Install]
WantedBy=multi-user.target
"""
    with open(SERVICE_UNIT, "w") as f:
        f.write(unit)
    print(f"wrote {SERVICE_UNIT}")
    subprocess.run(["systemctl", "daemon-reload"], check=False)
    subprocess.run(["systemctl", "enable", "--now", SERVICE_NAME], check=False)
    print(f"enabled + started {SERVICE_NAME}. Manage it with:")
    print(f"  systemctl status {SERVICE_NAME}   ·   journalctl -u {SERVICE_NAME} -f")
    print(f"  lattice status   ·   lattice down (or systemctl stop {SERVICE_NAME})")


def cmd_uninstall_service(sock, a):
    if platform.system() != "Linux":
        die("no systemd service to remove on this platform.")
    if not _is_root():
        die("uninstall-service must run as root (use sudo).")
    subprocess.run(["systemctl", "disable", "--now", SERVICE_NAME], check=False)
    if os.path.exists(SERVICE_UNIT):
        os.remove(SERVICE_UNIT)
        print(f"removed {SERVICE_UNIT}")
    subprocess.run(["systemctl", "daemon-reload"], check=False)
    print(f"{SERVICE_NAME} uninstalled.")


def cmd_install(sock, a):
    """Put `lattice` on PATH so you can run it from anywhere."""
    target = a.prefix
    dest = os.path.join(target, "lattice")
    src = os.path.abspath(__file__)
    if not os.access(target, os.W_OK):
        die(f"{target} is not writable — re-run with sudo, or pass --prefix DIR.")
    try:
        if os.path.lexists(dest):
            os.remove(dest)
        if a.copy:
            shutil.copy2(src, dest)
            os.chmod(dest, 0o755)
            print(f"copied lattice -> {dest}")
        else:
            os.symlink(src, dest)
            print(f"symlinked {dest} -> {src}")
    except OSError as e:
        die(f"install failed: {e}")
    print(f"run it from anywhere now:  lattice status")


def cmd_raw(sock, a):
    req = json.loads(a.json)
    print(json.dumps(call(sock, req), indent=2))


# ----------------------------- arg parser -----------------------------
def build_parser():
    p = argparse.ArgumentParser(
        prog="lattice", description="Friendly CLI for the Lattice v2 mesh daemon.")
    p.add_argument("--sock", default=DEFAULT_SOCK,
                   help=f"meshd socket (default {DEFAULT_SOCK})")
    sub = p.add_subparsers(dest="cmd", required=True)

    s = sub.add_parser("ls", help="list meshes on this computer")
    s.set_defaults(fn=cmd_ls)

    s = sub.add_parser("info", help="show one mesh (members, liveness, exit)")
    s.add_argument("mesh", help="mesh id or name")
    s.set_defaults(fn=cmd_info)

    s = sub.add_parser("new", help="create a new mesh (you become member #1)")
    s.add_argument("name", help="mesh label")
    s.add_argument("--me", default="me", help="your in-mesh name (default: me)")
    s.add_argument("--max", type=int, default=254, help="max members 1..254")
    s.add_argument("--cipher", default=None, help="data-plane cipher (see `lattice ciphers`)")
    s.add_argument("--ephemeral", action="store_true",
                   help="self-destruct keys when the mesh loses live quorum (default off)")
    s.add_argument("--master-gated", action="store_true", dest="master_gated",
                   help="only the creator may invite (default: any member can — open-chain)")
    s.add_argument("--expel", default=None,
                   help="who may expel a member: creator (default) | inviter | quorum[:k] | none")
    s.add_argument("--header", default=None,
                   help="header placement (P-C5): random (default) | front | back | fixed:N")
    s.set_defaults(fn=cmd_new)

    s = sub.add_parser("id", help="mint an identity code to hand to a mesh host")
    s.set_defaults(fn=cmd_id)

    s = sub.add_parser("invite", help="(host) mint an invite for a joiner's identity code")
    s.add_argument("mesh", help="mesh id or name")
    s.add_argument("name", help="the joiner's in-mesh name")
    s.add_argument("id_code", help="the joiner's identity code (from `lattice id`); '-' = read stdin")
    s.add_argument("--algo", default=None, help="invite-wrap algorithm (secrecy; see `lattice algos`)")
    s.set_defaults(fn=cmd_invite)

    s = sub.add_parser("join", help="join a mesh from an invite code")
    s.add_argument("invite_code", help="the invite code (from the host's `lattice invite`); '-' = read stdin")
    s.add_argument("--algo", default=None, help="invite-wrap algorithm the host used")
    s.set_defaults(fn=cmd_join)

    s = sub.add_parser("exit", help="pick which member is the internet exit")
    s.add_argument("mesh", help="mesh id or name")
    s.add_argument("member", help="member id or name")
    s.set_defaults(fn=cmd_exit)

    s = sub.add_parser("vpn", help="route ALL internet traffic through the mesh exit")
    s.add_argument("mesh", help="mesh id or name")
    s.set_defaults(fn=cmd_vpn)

    s = sub.add_parser("off", help="stop full tunnel; back to direct internet")
    s.set_defaults(fn=cmd_off)

    s = sub.add_parser("recipher", help="rotate the mesh key (evicts offline members)")
    s.add_argument("mesh", help="mesh id or name")
    s.add_argument("--cipher", default=None, help="optionally switch cipher too")
    s.set_defaults(fn=cmd_recipher)

    s = sub.add_parser("attack", help="raise an attack alert (one-veto self-destruct)")
    s.add_argument("mesh", help="mesh id or name")
    s.set_defaults(fn=cmd_attack)

    s = sub.add_parser("allclear", help="(creator) cancel an attack alert")
    s.add_argument("mesh", help="mesh id or name")
    s.set_defaults(fn=cmd_allclear)

    s = sub.add_parser("traffic", help="traffic monitor: per-peer bytes/packets (+ --detail flows)")
    s.add_argument("mesh", nargs="?", default=None, help="mesh id/name (omit = whole computer)")
    s.add_argument("--detail", action="store_true", help="also show recent packet flows (view B)")
    s.set_defaults(fn=cmd_traffic)

    s = sub.add_parser("expel", help="expel (revoke) a member, per the mesh's expel policy")
    s.add_argument("mesh", help="mesh id or name")
    s.add_argument("member", help="member id or name to expel")
    s.set_defaults(fn=cmd_expel)

    s = sub.add_parser("flows", help="show/edit the SDN flow table (routing rules)")
    s.add_argument("mesh", help="mesh id or name")
    s.add_argument("--block", metavar="CIDR", help="drop traffic to a destination (e.g. 1.1.1.1 or 10.0.0.0/8)")
    s.add_argument("--exit", metavar="CIDR", help="route a destination via the mesh exit")
    s.add_argument("--reset", action="store_true", help="reset to the default table")
    s.set_defaults(fn=cmd_flows)

    s = sub.add_parser("rm", help="wipe a mesh from this computer")
    s.add_argument("mesh", help="mesh id or name")
    s.set_defaults(fn=cmd_rm)

    # -------- server / daemon lifecycle (headless machines) --------
    def add_meshd_flags(sp):
        sp.add_argument("--meshd", default=None, help="path to the meshd binary (else auto-detect)")
        sp.add_argument("--advertise", default=None, metavar="IP:PORT",
                        help="pin this node's public address (exit/public node)")
        sp.add_argument("--state-dir", dest="state_dir", default=None,
                        help="persistence dir (default ~/.lattice/meshd)")
        sp.add_argument("--dht-port", dest="dht_port", type=int, default=None, help="DHT UDP port")
        sp.add_argument("--dht-bootstrap", dest="dht_bootstrap", default=None, metavar="IP:PORT",
                        help="DHT seed node(s) to bootstrap from (client behind NAT)")
        sp.add_argument("--bind-port", dest="bind_port", type=int, default=None,
                        help="pin the per-mesh data-plane UDP port (single-open-port hosts)")
        sp.add_argument("--no-dht", dest="no_dht", action="store_true", help="disable DHT rendezvous")
        sp.add_argument("--log", default=DEFAULT_LOG, help=f"daemon log file (default {DEFAULT_LOG})")

    s = sub.add_parser("up", help="start meshd in the background (headless server)")
    add_meshd_flags(s)
    s.add_argument("--foreground", action="store_true", help="run in this terminal (Ctrl-C to stop)")
    s.set_defaults(fn=cmd_up)

    s = sub.add_parser("down", help="stop the daemon cleanly (no sudo; = shutdown)")
    s.set_defaults(fn=cmd_down)

    s = sub.add_parser("restart", help="stop then start the daemon")
    add_meshd_flags(s)
    s.add_argument("--foreground", action="store_true", help=argparse.SUPPRESS)
    s.set_defaults(fn=cmd_restart)

    s = sub.add_parser("status", help="one-line daemon health + mesh/exit/traffic summary")
    s.add_argument("--meshd", default=None, help=argparse.SUPPRESS)
    s.add_argument("--log", default=DEFAULT_LOG, help=argparse.SUPPRESS)
    s.add_argument("--watch", type=int, default=0, metavar="SECS", help="redraw every SECS seconds")
    s.set_defaults(fn=cmd_status)

    s = sub.add_parser("logs", help="show the daemon log (-f to follow)")
    s.add_argument("-f", "--follow", action="store_true", help="follow new lines (tail -f)")
    s.add_argument("-n", "--lines", type=int, default=80, help="lines to show (default 80)")
    s.add_argument("--log", default=DEFAULT_LOG, help=argparse.SUPPRESS)
    s.set_defaults(fn=cmd_logs)

    s = sub.add_parser("serve-exit", help="make THIS node the internet exit for a mesh")
    s.add_argument("mesh", help="mesh id or name")
    s.add_argument("--advertise", default=None, metavar="IP:PORT",
                   help="your public address (reminds you to pin it on restart)")
    s.set_defaults(fn=cmd_serve_exit)

    s = sub.add_parser("install-service", help="install a systemd unit so meshd starts at boot (Linux)")
    add_meshd_flags(s)
    s.set_defaults(fn=cmd_install_service)

    s = sub.add_parser("uninstall-service", help="remove the systemd unit (Linux)")
    s.set_defaults(fn=cmd_uninstall_service)

    s = sub.add_parser("install", help="put `lattice` on PATH (symlink, or --copy)")
    s.add_argument("--prefix", default="/usr/local/bin", help="install dir (default /usr/local/bin)")
    s.add_argument("--copy", action="store_true", help="copy instead of symlink")
    s.set_defaults(fn=cmd_install)

    s = sub.add_parser("shutdown", help="cleanly stop the daemon (no sudo)")
    s.set_defaults(fn=cmd_shutdown)

    s = sub.add_parser("ciphers", help="list available data-plane ciphers")
    s.set_defaults(fn=cmd_ciphers)
    s = sub.add_parser("algos", help="list invite-wrap algorithms")
    s.set_defaults(fn=cmd_algos)
    s = sub.add_parser("policy", help="show the current routing policy")
    s.set_defaults(fn=cmd_policy)

    s = sub.add_parser("backup", help="snapshot meshes to a file for update migration")
    s.add_argument("path", nargs="?", default=None,
                   help="output path (default: <tempdir>/lattice-mesh-backup.json)")
    s.set_defaults(fn=cmd_backup)

    s = sub.add_parser("doctor", help="diagnose mesh health + suggest fixes")
    s.add_argument("mesh", nargs="?", default=None,
                   help="mesh id or name (default: check every mesh)")
    s.set_defaults(fn=cmd_doctor)

    s = sub.add_parser("raw", help="send a raw JSON request (escape hatch)")
    s.add_argument("json", help='e.g. \'{"ListMeshes":null}\'')
    s.set_defaults(fn=cmd_raw)
    return p


def main():
    args = build_parser().parse_args()
    args.fn(args.sock, args)


if __name__ == "__main__":
    main()
